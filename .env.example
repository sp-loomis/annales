# Local dev — matches docker-compose.yml
DATABASE_URL=postgresql://sheaf:sheaf@localhost:5433/sheaf
S3_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
S3_BUCKET=sheaf-dev
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
UPLOAD_TTL_SECONDS=900
PORT=3000

# Local mode (npm run local) overrides these at runtime:
# DATABASE_URL=postgresql://sheaf:sheaf@localhost:5433/sheaf_local
# S3_BUCKET=sheaf-local
# PORT=3001
# Vite frontend runs on :5174 and proxies /api to :3001
