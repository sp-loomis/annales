generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model World {
  id             String          @id @default(uuid())
  name           String
  entries        Entry[]
  entryTypes     EntryType[]
  globes         Globe[]
  timelines      Timeline[]
  relationTypes  RelationType[]
  theme          WorldTheme?
  workspaceState WorkspaceState?
}

// Per-world registry of entry types. Entry.typeId references this; the slug
// (not the uuid) is what API responses expose. Defaults seeded on world create.
model EntryType {
  id         String  @id @default(uuid())
  worldId    String
  name       String // display label e.g. "Character"
  slug       String // API/storage value e.g. "character"
  iconName   String? // Phosphor icon identifier e.g. "User"
  iconWeight String? // "thin"|"light"|"regular"|"bold"|"fill"|"duotone"
  world      World   @relation(fields: [worldId], references: [id], onDelete: Cascade)
  entries    Entry[]

  @@unique([worldId, slug])
}

// A sphere grouping CRSs (its projections). Geometry bboxes canonicalize to
// this globe's surface (lng/lat degrees, prime meridian 0).
model Globe {
  id      String          @id @default(uuid())
  worldId String
  name    String
  params  Json
  world   World           @relation(fields: [worldId], references: [id], onDelete: Cascade)
  crs     CrsDefinition[]

  @@unique([worldId, name])
}

// A tick axis grouping calendars — a single tracker of fractional days from an
// absolute epoch. params reserved (epoch mapping lives in calendars for now).
model Timeline {
  id        String     @id @default(uuid())
  worldId   String
  name      String
  params    Json?
  world     World      @relation(fields: [worldId], references: [id], onDelete: Cascade)
  calendars Calendar[]

  @@unique([worldId, name])
}

model Entry {
  id        String   @id @default(uuid())
  typeId    String
  title     String
  worldId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  world         World      @relation(fields: [worldId], references: [id], onDelete: Cascade)
  type          EntryType  @relation(fields: [typeId], references: [id], onDelete: Restrict)
  tags          EntryTag[]
  sections      Section[]
  images        Image[]
  sketches      Sketch[]
  geometries    Geometry[]
  dateRanges    DateRange[]
  relationsFrom Relation[] @relation("RelationFrom")
  relationsTo   Relation[] @relation("RelationTo")

  @@index([worldId, typeId])
}

model EntryTag {
  entryId String
  tag     String
  entry   Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@id([entryId, tag])
  @@index([tag])
}

// Rich-text sections hold ProseMirror JSON directly in the DB (no S3 file, no
// upload lifecycle). Plain text is extracted into SearchIndex on write.
model Section {
  id          String @id @default(uuid())
  entryId     String
  contentJson Json?
  order       Float
  entry       Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

// File-backed artifacts (Image/Sketch/Geometry) share the presigned upload
// lifecycle: status 'pending' at create, 'ready' after finalize. 'failed' is
// never stored — derived at read time from uploadExpiresAt.
model Image {
  id              String    @id @default(uuid())
  entryId         String
  label           String?
  contentType     String
  filePath        String    @unique
  status          String    @default("pending")
  uploadExpiresAt DateTime?
  order           Float
  entry           Entry     @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model Sketch {
  id              String    @id @default(uuid())
  entryId         String
  label           String?
  filePath        String    @unique
  status          String    @default("pending")
  uploadExpiresAt DateTime?
  order           Float
  entry           Entry     @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model Geometry {
  id              String        @id @default(uuid())
  entryId         String
  crsId           String
  filePath        String        @unique
  label           String?
  properties      Json?
  status          String        @default("pending")
  uploadExpiresAt DateTime?
  order           Float
  entry           Entry         @relation(fields: [entryId], references: [id], onDelete: Cascade)
  crs             CrsDefinition @relation(fields: [crsId], references: [id], onDelete: Restrict)
  // Canonical lng/lat bbox(es), derived at finalize; empty while pending. 1 box
  // normally, 2 across the antimeridian. GiST index hand-added in the migration.
  boxes           GeometryBox[]
}

model GeometryBox {
  id         String             @id @default(uuid())
  geometryId String
  box        Unsupported("box")
  geometry   Geometry           @relation(fields: [geometryId], references: [id], onDelete: Cascade)

  @@index([geometryId])
}

// A projection of its globe's sphere. params is a d3-geo projection spec:
// { type, rotate: [lambda, phi, gamma], clipAngle }.
model CrsDefinition {
  id         String     @id @default(uuid())
  globeId    String
  name       String
  params     Json
  globe      Globe      @relation(fields: [globeId], references: [id], onDelete: Cascade)
  geometries Geometry[]

  @@unique([globeId, name])
}

model DateRange {
  id            String   @id @default(uuid())
  entryId       String
  calendarId    String
  rawComponents Json
  tickStart     BigInt?
  tickEnd       BigInt?
  precisionTier String
  label         String?
  displayStyle  String   @default("pretty")
  entry         Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  calendar      Calendar @relation(fields: [calendarId], references: [id], onDelete: Restrict)

  @@index([tickStart])
  @@index([tickEnd])
}

model Calendar {
  id         String      @id @default(uuid())
  timelineId String
  name       String
  definition Json
  timeline   Timeline    @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  dateRanges DateRange[]

  @@unique([timelineId, name])
}

model RelationType {
  id          String     @id @default(uuid())
  worldId     String
  name        String
  inverseName String?
  iconName    String?
  iconWeight  String?
  world       World      @relation(fields: [worldId], references: [id], onDelete: Cascade)
  relations   Relation[]

  @@unique([worldId, name])
}

model Relation {
  id     String       @id @default(uuid())
  fromId String
  toId   String
  typeId String
  from   Entry        @relation("RelationFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to     Entry        @relation("RelationTo", fields: [toId], references: [id], onDelete: Cascade)
  type   RelationType @relation(fields: [typeId], references: [id], onDelete: Restrict)

  @@unique([fromId, toId, typeId])
  @@index([toId])
}

// One row per (artifact, extracted text). Both text and tsv are derived at
// finalize time — text is kept so ts_headline can build snippets without a
// storage round trip; the file remains the source of truth.
// GIN index added by hand in the migration.
model SearchIndex {
  id         String                  @id @default(uuid())
  entryId    String
  sourceType String
  sourceId   String
  text       String
  tsv        Unsupported("tsvector")

  @@unique([sourceType, sourceId])
  @@index([entryId])
}

// UI persistence — one row per world, keyed by worldId. GET returns column
// defaults when absent (never 404); PUT upserts.
model WorldTheme {
  worldId           String  @id
  fontFamily        String?
  accentColor       String?
  surfaceColor      String?
  darkMode          Boolean @default(true)
  defaultIconWeight String  @default("duotone")
  uiScale           String  @default("small")
  world             World   @relation(fields: [worldId], references: [id], onDelete: Cascade)
}

model WorkspaceState {
  worldId      String   @id
  openEntryIds String[]
  sidebarState Json?
  updatedAt    DateTime @updatedAt
  world        World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
}
